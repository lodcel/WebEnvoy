{
  "id": "loom-init",
  "role": "bootstrap/root",
  "contract_version": "1.3.0",
  "display_name": "Loom Init",
  "description": "Bootstrap Loom into a target repository and route operators to the right scenario skill when the task is not a fresh initialization request.",
  "root_entry": true,
  "entrypoint": {
    "skill_markdown": "SKILL.md",
    "adapter_metadata": "agents/openai.yaml",
    "bootstrap_cli": "scripts/loom-init.py",
    "route_cli": "scripts/loom-init.py"
  },
  "input_contract": {
    "reference": "references/input-signals.md",
    "required_fields": [
      "repository_type",
      "root_boundary_docs",
      "ci_or_basic_tests",
      "repository_level_validation_entry",
      "primary_gap_category",
      "long_running_recovery_pain",
      "shared_contract_or_high_risk_boundary",
      "purity_or_scope_signals",
      "merge_review_semantic_overload",
      "maturity",
      "adoption_intent"
    ]
  },
  "output_contract": {
    "reference": "references/output-contract.md",
    "required_sections": [
      "project_judgment",
      "recommended_adoption",
      "scaffold_profile",
      "adoption_intent",
      "detected_repository_mode",
      "risk_summary",
      "required_carriers",
      "planned_writes",
      "forbidden_authored_carriers",
      "deferred_capabilities",
      "upgrade_triggers",
      "fact_chain",
      "initial_artifacts",
      "initial_work_items",
      "runtime_state",
      "validation_and_closing"
    ]
  },
  "routing": {
    "reference": "../route-matrix.md",
    "priority_order": [
      "explicit skill name",
      "task signal routing",
      "fallback to loom-init with missing inputs"
    ],
    "fallback_entry": "loom-init"
  },
  "artifact_mapping": {
    "rules": [
      "../shared/references/governance",
      "../shared/references/harness",
      "../shared/references/templates",
      "../shared/references/adoption"
    ],
    "skill_refs": [
      "references/input-signals.md",
      "references/intake-signals.md",
      "references/output-contract.md"
    ],
    "default_targets": [
      ".loom/bootstrap/init-result.json",
      ".loom/work-items/INIT-0001.md",
      ".loom/progress/INIT-0001.md",
      ".loom/status/current.md",
      ".loom/specs/INIT-0001/spec.md",
      ".loom/specs/INIT-0001/plan.md"
    ]
  },
  "installation": {
    "registry": "../registry.json",
    "upgrade_contract": "../upgrade-contract.json",
    "layout_manifest": "../install-layout.json"
  }
}
