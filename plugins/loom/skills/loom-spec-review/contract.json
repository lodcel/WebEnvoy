{
  "id": "loom-spec-review",
  "role": "scenario/spec-review",
  "contract_version": "1.0.0",
  "display_name": "Loom Spec Review",
  "description": "Run the formal spec review flow and return the spec gate consumed by implementation review and merge-ready.",
  "root_entry": false,
  "entrypoint": {
    "skill_markdown": "SKILL.md",
    "adapter_metadata": "agents/openai.yaml",
    "orchestration_cli": "scripts/loom-spec-review.py"
  },
  "input_contract": {
    "reference": "references/input-signals.md",
    "required_fields": [
      "target_repository",
      "current_item_or_active_item",
      "formal_spec_path_or_spec_review_intent"
    ]
  },
  "output_contract": {
    "reference": "references/output-contract.md",
    "required_sections": [
      "item",
      "result",
      "summary",
      "missing_inputs",
      "fallback_to",
      "runtime_state",
      "steps",
      "state_check",
      "runtime_evidence",
      "build_checkpoint",
      "spec_review",
      "current_checkpoint"
    ]
  },
  "routing": {
    "reference": ".loom-runtime/route-matrix.md",
    "explicit_name": "loom-spec-review"
  },
  "installation": {
    "registry": ".loom-runtime/registry.json",
    "upgrade_contract": ".loom-runtime/upgrade-contract.json",
    "layout_manifest": ".loom-runtime/install-layout.json"
  }
}
