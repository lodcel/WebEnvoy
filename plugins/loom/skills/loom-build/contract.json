{
  "id": "loom-build",
  "role": "scenario/build",
  "contract_version": "1.0.0",
  "display_name": "Loom Build",
  "description": "Run a bounded implementation/build readiness flow between resume and pre-review, including subagent-driven execution evidence.",
  "root_entry": false,
  "entrypoint": {
    "skill_markdown": "SKILL.md",
    "adapter_metadata": "agents/openai.yaml",
    "orchestration_cli": "scripts/loom-build.py"
  },
  "input_contract": {
    "reference": "references/input-signals.md",
    "required_fields": [
      "target_repository",
      "current_item_or_active_item",
      "work_item",
      "spec",
      "plan",
      "recovery_baseline",
      "validation_baseline",
      "workspace",
      "ownership_constraints"
    ]
  },
  "output_contract": {
    "reference": "references/output-contract.md",
    "required_sections": [
      "item",
      "result",
      "summary",
      "missing_inputs",
      "fallback_to",
      "runtime_state",
      "state_check",
      "runtime_evidence",
      "build_execution",
      "steps"
    ]
  },
  "routing": {
    "reference": ".loom-runtime/route-matrix.md",
    "explicit_name": "loom-build"
  },
  "installation": {
    "registry": ".loom-runtime/registry.json",
    "upgrade_contract": ".loom-runtime/upgrade-contract.json",
    "layout_manifest": ".loom-runtime/install-layout.json"
  }
}
