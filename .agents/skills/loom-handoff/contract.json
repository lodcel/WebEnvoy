{
  "id": "loom-handoff",
  "role": "scenario/handoff",
  "contract_version": "1.3.0",
  "display_name": "Loom Handoff",
  "description": "Produce the minimum handoff writeback checklist and locator set without creating a second authored truth source.",
  "root_entry": false,
  "entrypoint": {
    "skill_markdown": "SKILL.md",
    "adapter_metadata": "agents/openai.yaml",
    "orchestration_cli": "scripts/loom-handoff.py"
  },
  "input_contract": {
    "reference": "references/input-signals.md",
    "required_fields": [
      "target_repository",
      "current_item_or_active_item",
      "handoff_intent"
    ]
  },
  "output_contract": {
    "reference": "references/output-contract.md",
    "required_sections": [
      "item",
      "result",
      "summary",
      "missing_inputs",
      "fallback_to",
      "runtime_state",
      "workspace",
      "checkpoint",
      "state_check",
      "steps",
      "recovery_entry",
      "status_surface",
      "current_stop",
      "next_step",
      "blockers",
      "latest_validation_summary",
      "fallback_target",
      "writeback_fields"
    ]
  },
  "routing": {
    "reference": ".loom-runtime/route-matrix.md",
    "explicit_name": "loom-handoff"
  },
  "installation": {
    "registry": ".loom-runtime/registry.json",
    "upgrade_contract": ".loom-runtime/upgrade-contract.json",
    "layout_manifest": ".loom-runtime/install-layout.json"
  }
}
